{
  "mcpServers": {
    "aponi-local": {
      "type": "local",
      "command": "python",
      "args": [
        "-m",
        "runtime.mcp.server",
        "--server",
        "aponi-local"
      ],
      "tools": [
        "system_intelligence",
        "risk_summary",
        "evolution_timeline",
        "replay_diff",
        "policy_simulate",
