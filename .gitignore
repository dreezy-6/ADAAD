__pycache__/
*.py[cod]
*.log
.env
.venv/
.envrc
.tmp/
.pytest_cache/
.mypy_cache/

# Data and telemetry
/data/quarantine/*
!/data/quarantine/.gitkeep
/data/adad.sqlite3

# Editor artifacts
*.swp
.DS_Store
.idea/
.vscode/

# Signatures and releases
*.sig
*.zip

# Allow directory keepers
!**/.gitkeep

# Runtime logs (generated; not tracked)
/data/logs/*.jsonl

/reports/metrics.jsonl
/reports/system_dependency_graph.json
/logs/*.log
/logs/*.jsonl
/security/ledger/*.jsonl
!/security/ledger/cryovant_journal.genesis.jsonl
/security/ledger/gate_hash.txt

# Never commit private keys
security/keys/*
!security/keys/.gitkeep
venv/
reports/
data/work/
data/logs/
security/ledger/*.lock
*.lock
runtime/evolution/state/
app/agents/
