{
  "$id": "https://adaad.local/schemas/evidence_bundle.v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "bundle_id": {
      "type": "string"
    },
    "bundle_index": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "bundle_digest": {
            "type": "string"
          },
          "bundle_id": {
            "type": "string"
          },
          "certificate": {
            "type": "object"
          },
          "epoch_digest": {
            "type": "string"
          },
          "epoch_id": {
            "type": "string"
          },
          "risk_tier": {
            "type": "string"
          }
        },
        "required": [
          "epoch_id",
          "bundle_id",
          "bundle_digest",
          "epoch_digest",
          "risk_tier",
          "certificate"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "constitution_version": {
      "type": "string"
    },
    "export_metadata": {
      "additionalProperties": false,
      "properties": {
        "access_scope": {
          "minLength": 1,
          "type": "string"
        },
        "canonical_ordering": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        },
        "environment": {
          "additionalProperties": false,
          "properties": {
            "container_hash": {
              "type": "string"
            },
            "digest_algorithm": {
              "type": "string"
            },
            "dispatcher_version": {
              "type": "string"
            },
            "python_version": {
              "type": "string"
            },
            "runtime_build_hash": {
              "type": "string"
            }
          },
          "required": [
            "dispatcher_version",
            "digest_algorithm",
            "runtime_build_hash",
            "python_version",
            "container_hash"
          ],
          "type": "object"
        },
        "immutable": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "retention_days": {
          "minimum": 1,
          "type": "number"
        },
        "signer": {
          "additionalProperties": false,
          "properties": {
            "algorithm": {
              "minLength": 1,
              "type": "string"
            },
            "key_id": {
              "minLength": 1,
              "type": "string"
            },
            "signature": {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            "signed_digest": {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            }
          },
          "required": [
            "key_id",
            "algorithm",
            "signed_digest",
            "signature"
          ],
          "type": "object"
        }
      },
      "required": [
        "digest",
        "canonical_ordering",
        "immutable",
        "path",
        "retention_days",
        "access_scope",
        "signer"
      ],
      "type": "object"
    },
    "export_scope": {
      "additionalProperties": false,
      "properties": {
        "epoch_end": {
          "type": "string"
        },
        "epoch_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "epoch_start": {
          "type": "string"
        }
      },
      "required": [
        "epoch_start",
        "epoch_end",
        "epoch_ids"
      ],
      "type": "object"
    },
    "federated_evidence": {
      "additionalProperties": false,
      "properties": {
        "divergence_count": {
          "type": "number"
        },
        "epoch_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "failed_count": {
          "type": "number"
        },
        "invariant_ok": {
          "type": "boolean"
        },
        "passed_count": {
          "type": "number"
        },
        "schema_version": {
          "type": "string"
        },
        "verification_count": {
          "type": "number"
        },
        "verifications": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "epoch_id": {
                "type": "string"
              },
              "failure_codes": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "has_divergence": {
                "type": "boolean"
              },
              "matrix_digest": {
                "type": "string"
              },
              "passed": {
                "type": "boolean"
              },
              "proposal_id": {
                "type": "string"
              }
            },
            "required": [
              "epoch_id",
              "proposal_id",
              "passed",
              "failure_codes",
              "matrix_digest",
              "has_divergence"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "required": [
        "schema_version",
        "epoch_ids",
        "verification_count",
        "passed_count",
        "failed_count",
        "divergence_count",
        "invariant_ok",
        "verifications"
      ],
      "type": "object"
    },
    "fitness_weights_hash": {
      "type": "string"
    },
    "goal_graph_hash": {
      "type": "string"
    },
    "governor_version": {
      "type": "string"
    },
    "lineage_anchors": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "bundle_ids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "epoch_id": {
            "type": "string"
          },
          "expected_epoch_digest": {
            "type": "string"
          },
          "incremental_epoch_digest": {
            "type": "string"
          }
        },
        "required": [
          "epoch_id",
          "expected_epoch_digest",
          "incremental_epoch_digest",
          "bundle_ids"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "policy_artifact_metadata": {
      "additionalProperties": false,
      "properties": {
        "fingerprint": {
          "type": "string"
        },
        "model": {
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "version": {
              "type": "string"
            }
          },
          "required": [
            "name",
            "version"
          ],
          "type": "object"
        },
        "path": {
          "type": "string"
        },
        "schema_version": {
          "type": "string"
        },
        "thresholds": {
          "additionalProperties": false,
          "properties": {
            "determinism_pass": {
              "type": "number"
            },
            "determinism_warn": {
              "type": "number"
            }
          },
          "required": [
            "determinism_pass",
            "determinism_warn"
          ],
          "type": "object"
        }
      },
      "required": [
        "path",
        "schema_version",
        "fingerprint",
        "model",
        "thresholds"
      ],
      "type": "object"
    },
    "replay_proofs": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "canonical_digest": {
            "type": "string"
          },
          "digest": {
            "type": "string"
          },
          "epoch_id": {
            "type": "string"
          },
          "event_count": {
            "type": "number"
          },
          "sandbox_replay": {
            "items": {
              "type": "object"
            },
            "type": "array"
          }
        },
        "required": [
          "epoch_id",
          "digest",
          "canonical_digest",
          "event_count",
          "sandbox_replay"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "risk_summaries": {
      "additionalProperties": false,
      "properties": {
        "bundle_count": {
          "type": "number"
        },
        "high_risk_bundle_count": {
          "type": "number"
        },
        "replay_proof_count": {
          "type": "number"
        },
        "sandbox_evidence_count": {
          "type": "number"
        }
      },
      "required": [
        "bundle_count",
        "sandbox_evidence_count",
        "replay_proof_count",
        "high_risk_bundle_count"
      ],
      "type": "object"
    },
    "sandbox_evidence": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "bundle_id": {
            "type": "string"
          },
          "entry_hash": {
            "type": "string"
          },
          "epoch_id": {
            "type": "string"
          },
          "evidence_hash": {
            "type": "string"
          },
          "manifest_hash": {
            "type": "string"
          },
          "policy_hash": {
            "type": "string"
          },
          "prev_hash": {
            "type": "string"
          }
        },
        "required": [
          "epoch_id",
          "bundle_id",
          "evidence_hash",
          "manifest_hash",
          "policy_hash",
          "entry_hash",
          "prev_hash"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "sandbox_snapshot": {
      "additionalProperties": false,
      "properties": {
        "namespace_isolation_available": {
          "type": "boolean"
        },
        "seccomp_available": {
          "type": "boolean"
        },
        "syscall_allowlist": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "workspace_prefixes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "seccomp_available",
        "namespace_isolation_available",
        "workspace_prefixes",
        "syscall_allowlist"
      ],
      "type": "object"
    },
    "schema_version": {
      "type": "string"
    },
    "scoring_algorithm_version": {
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "constitution_version",
    "scoring_algorithm_version",
    "governor_version",
    "fitness_weights_hash",
    "goal_graph_hash",
    "bundle_id",
    "export_scope",
    "replay_proofs",
    "sandbox_evidence",
    "policy_artifact_metadata",
    "risk_summaries",
    "lineage_anchors",
    "bundle_index",
    "export_metadata",
    "sandbox_snapshot"
  ],
  "type": "object"
}
