{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adaad.local/schemas/checkpoint_chain_event.v1.json",
  "title": "Checkpoint Chain Governance Event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_type",
    "epoch_id",
    "checkpoint_count",
    "verified",
    "halt_reason_code",
    "halt_reason_detail",
    "last_verified_checkpoint_hash",
    "prior_checkpoint_chain_event_hash"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "event_type": {
      "type": "string",
      "enum": ["checkpoint_chain_verified", "checkpoint_chain_violated"]
    },
    "epoch_id": {"type": "string", "minLength": 1},
    "checkpoint_count": {"type": "integer", "minimum": 0},
    "verified": {"type": "boolean"},
    "halt_reason_code": {"type": "string"},
    "halt_reason_detail": {"type": "string"},
    "last_verified_checkpoint_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "prior_checkpoint_chain_event_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
  },
  "allOf": [
    {
      "if": {"properties": {"event_type": {"const": "checkpoint_chain_verified"}}},
      "then": {
        "properties": {
          "verified": {"const": true},
          "halt_reason_code": {"const": ""},
          "halt_reason_detail": {"const": ""}
        }
      }
    },
    {
      "if": {"properties": {"event_type": {"const": "checkpoint_chain_violated"}}},
      "then": {
        "properties": {
          "verified": {"const": false},
          "halt_reason_code": {"minLength": 1},
          "halt_reason_detail": {"minLength": 1}
        }
      }
    }
  ]
}
