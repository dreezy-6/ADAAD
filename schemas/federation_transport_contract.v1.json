{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adaad.local/schemas/federation_transport_contract.v1.json",
  "title": "Federation Transport Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "protocol",
    "protocol_version",
    "envelope_id",
    "source_peer_id",
    "target_peer_id",
    "sent_at_epoch",
    "handshake"
  ],
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "https://adaad.local/schemas/federation_transport_contract.v1.json"
    },
    "protocol": {
      "type": "string",
      "const": "adaad.federation.transport"
    },
    "protocol_version": {
      "type": "string",
      "const": "1.0"
    },
    "envelope_id": {
      "type": "string",
      "minLength": 1
    },
    "source_peer_id": {
      "type": "string",
      "minLength": 1
    },
    "target_peer_id": {
      "type": "string",
      "minLength": 1
    },
    "sent_at_epoch": {
      "type": "integer",
      "minimum": 0
    },
    "handshake": {
      "type": "object",
      "additionalProperties": false,
      "required": ["peer_id", "policy_version", "manifest_digest", "decision"],
      "properties": {
        "peer_id": {"type": "string", "minLength": 1},
        "policy_version": {"type": "string", "minLength": 1},
        "manifest_digest": {"type": "string", "pattern": "^sha256:[a-zA-Z0-9]+"},
        "decision": {"type": "string", "enum": ["accept", "reject"]},
        "is_local": {"type": "boolean"}
      }
    }
  }
}
