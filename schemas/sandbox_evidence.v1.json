{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adaad.local/schemas/sandbox_evidence.v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_hash",
    "policy_hash",
    "sandbox_policy_hash",
    "stdout_hash",
    "stderr_hash",
    "syscall_trace_hash",
    "syscall_fingerprint",
    "resource_usage",
    "exit_code",
    "replay_seed",
    "timestamp",
    "evidence_hash",
    "manifest",
    "isolation_mode",
    "enforced_controls",
    "preflight",
    "events",
    "runtime_telemetry_hash",
    "replay_environment_fingerprint",
    "replay_environment_fingerprint_hash",
    "runtime_version_hash",
    "dependency_lock_digest_hash",
    "container_profile_digest_hash",
    "filesystem_snapshot_digest_hash",
    "seed_lineage_hash",
    "replay_diagnostics",
    "replay_diagnostics_hash"
  ],
  "properties": {
    "manifest_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "policy_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "stdout_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "stderr_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "syscall_trace_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "resource_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "duration_s",
        "memory_mb",
        "disk_mb"
      ],
      "properties": {
        "duration_s": {
          "type": "number",
          "minimum": 0
        },
        "memory_mb": {
          "type": "number",
          "minimum": 0
        },
        "disk_mb": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "exit_code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "replay_seed": {
      "type": "string",
      "pattern": "^(?!0{16}$)[a-fA-F0-9]{16}$"
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "evidence_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "manifest": {
      "type": "object"
    },
    "isolation_mode": {
      "type": "string",
      "minLength": 1
    },
    "enforced_controls": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "control",
          "profile",
          "mechanism",
          "enforced",
          "simulated"
        ],
        "properties": {
          "control": {
            "type": "string",
            "minLength": 1
          },
          "profile": {
            "type": "string",
            "minLength": 1
          },
          "mechanism": {
            "type": "string",
            "minLength": 1
          },
          "enforced": {
            "type": "boolean"
          },
          "simulated": {
            "type": "boolean"
          }
        }
      }
    },
    "preflight": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "ok",
        "reason"
      ],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sandbox_policy_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "syscall_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "event"
        ],
        "properties": {
          "event": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "runtime_telemetry": {
      "type": "object",
      "additionalProperties": true
    },
    "runtime_telemetry_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "replay_environment_fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_version",
        "dependency_lock_digest",
        "container_profile_digest",
        "filesystem_snapshot_digest",
        "seed_lineage"
      ],
      "properties": {
        "runtime_version": {
          "type": "string",
          "minLength": 1
        },
        "dependency_lock_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "container_profile_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "filesystem_snapshot_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "seed_lineage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "root_seed",
            "parent_seed",
            "current_seed"
          ],
          "properties": {
            "root_seed": {
              "type": "string"
            },
            "parent_seed": {
              "type": "string"
            },
            "current_seed": {
              "type": "string"
            }
          }
        }
      }
    },
    "replay_environment_fingerprint_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "runtime_version_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "dependency_lock_digest_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "container_profile_digest_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "filesystem_snapshot_digest_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "seed_lineage_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "replay_diagnostics_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "replay_diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "added",
        "removed",
        "modified",
        "post_filesystem_snapshot_digest"
      ],
      "properties": {
        "added": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "removed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "modified": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "post_filesystem_snapshot_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    }
  }
}
