{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adaad.local/schemas/federation_replay_proof_bundle.v1.json",
  "title": "Federation Replay Proof Bundle Message v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "message_type", "payload", "digest", "signature"],
  "properties": {
    "schema_id": {"type": "string", "const": "https://adaad.local/schemas/federation_replay_proof_bundle.v1.json"},
    "message_type": {"type": "string", "const": "replay_proof_bundle"},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bundle_id", "exchange_id", "source_peer_id", "proof_digest", "attestation_digest", "sent_at_epoch"],
      "properties": {
        "bundle_id": {"type": "string", "minLength": 1},
        "exchange_id": {"type": "string", "minLength": 1},
        "source_peer_id": {"type": "string", "minLength": 1},
        "proof_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "attestation_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "sent_at_epoch": {"type": "integer", "minimum": 0}
      }
    },
    "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "public_key", "value"],
      "properties": {
        "algorithm": {"type": "string", "const": "ed25519"},
        "key_id": {"type": "string", "minLength": 1},
        "public_key": {"type": "string", "minLength": 1},
        "value": {"type": "string", "minLength": 1}
      }
    }
  }
}
