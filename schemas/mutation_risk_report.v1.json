{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adaad.local/schemas/mutation_risk_report.v1.json",
  "title": "Mutation Risk Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mutation_id",
    "generated_at",
    "score",
    "threshold",
    "threshold_exceeded",
    "report_sha256",
    "file_scores"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "mutation_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "threshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "threshold_exceeded": {
      "type": "boolean"
    },
    "report_sha256": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    },
    "file_scores": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "score",
          "changed_lines",
          "ast_relevant_change",
          "reasons"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "changed_lines": {
            "type": "integer",
            "minimum": 1
          },
          "ast_relevant_change": {
            "type": "boolean"
          },
          "reasons": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
